{
  "table": "shopify_pixel_events",
  "dataset": "raw_dev",
  "description": "Append-only raw event ledger. No transformations.",
  "fields": [
    { "name": "received_at",   "type": "TIMESTAMP", "mode": "REQUIRED" },
    { "name": "source",        "type": "STRING",    "mode": "REQUIRED" },
    { "name": "shopify_event", "type": "STRING",    "mode": "NULLABLE" },
    { "name": "event_id",      "type": "STRING",    "mode": "NULLABLE" },
    { "name": "payload",       "type": "JSON",      "mode": "REQUIRED" },
    { "name": "th_vid",        "type": "STRING",    "mode": "NULLABLE" },
    { "name": "session_key",   "type": "STRING",    "mode": "NULLABLE" },
    { "name": "session_start", "type": "TIMESTAMP", "mode": "NULLABLE" }
  ]
}
