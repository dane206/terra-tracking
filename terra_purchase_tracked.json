{% if first_time_accessed %}
<script>
(function () {
  try {
    if (localStorage.getItem('terra_purchase_tracked') === 'true') return;

    var order = window.Shopify && window.Shopify.order;
    if (!order || !order.id || !order.lineItems || !order.totalPrice) return;

    function uuidv4() {
      return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
        var r = Math.random() * 16 | 0, v = c === 'x' ? r : (r & 0x3 | 0x8);
        return v.toString(16);
      });
    }

    var eventId = uuidv4();
    var ga4Id = 'G-2KQXE351HW';
    var gadsSendTo = 'AW-654961066/9mS-CIer3ssZEKrTp7gC'; // Update this if you're using a different live Ads conversion label
    var serverUrl = 'https://shopify-tracker-330159988892.us-central1.run.app/track';

    var items = order.lineItems.map(function (item, i) {
      return {
        item_id: item.sku || 'shopify_' + order.currency + '_' + item.productId + '_' + item.variantId,
        item_name: item.title,
        item_brand: item.vendor || 'Shopify',
        item_variant: item.variantTitle || '',
        item_category: item.productType || '',
        price: item.price,
        quantity: item.quantity,
        index: i
      };
    });

    var payload = {
      event: 'purchase',
      event_id: eventId,
      timestamp: new Date().toISOString(),
      page_location: window.location.href,
      page_referrer: document.referrer || null,
      transaction_id: String(order.id),
      value: order.totalPrice,
      currency: order.currency,
      affiliation: order.sourceName || 'Shopify',
      coupon: (order.discountApplications || []).map(function(d) { return d.code; }).join(','),
      user_id: window._terra_customer_id || null,
      visitor_id: (window._st && window._st.u) || null,
      items: items
    };

    // 1. Push to dataLayer
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'dl_purchase',
      event_id: eventId,
      ecommerce: {
        transaction_id: payload.transaction_id,
        value: payload.value,
        currency: payload.currency,
        items: payload.items
      }
    });

    // 2. Send to Cloud Run
    try {
      fetch(serverUrl, {
        method: 'POST',
        body: JSON.stringify(payload),
        headers: { 'Content-Type': 'application/json' }
      });
    } catch (e) {
      console.warn('[terra] Cloud Run tracking failed', e);
    }

    // 3. Fire gtag to GA4 + Ads
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
    gtag('js', new Date());
    gtag('config', ga4Id, { send_page_view: false });
    gtag('config', 'AW-654961066', { send_page_view: false });

    gtag('event', 'purchase', {
      send_to: [ga4Id, gadsSendTo],
      transaction_id: payload.transaction_id,
      value: payload.value,
      currency: payload.currency,
      items: payload.items,
      event_id: eventId
    });

    // 4. Deduplication lock
    localStorage.setItem('terra_purchase_tracked', 'true');
  } catch (err) {
    console.error('[terra] purchase tracking failure', err);
  }
})();
</script>
{% endif %}